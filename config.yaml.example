# Zenus Configuration
# Copy to ~/.zenus/config.yaml or ./zenus.yaml

version: "1.2.0"
profile: dev  # dev, staging, or production

# LLM Configuration
llm:
  provider: anthropic  # anthropic, openai, deepseek, ollama
  model: claude-3-5-sonnet-20241022
  max_tokens: 4096
  temperature: 0.7
  timeout_seconds: 30

# Fallback Chain (when primary LLM fails)
fallback:
  enabled: true
  providers:
    - anthropic
    - deepseek
    - rule_based

# Circuit Breaker (prevent cascade failures)
circuit_breaker:
  enabled: true
  failure_threshold: 5          # Open after 5 failures
  timeout_seconds: 60.0         # Try reset after 60s
  success_threshold: 2          # Close after 2 successes

# Retry Logic (prevent infinite retries)
retry:
  enabled: true
  max_attempts: 3
  initial_delay_seconds: 1.0
  max_delay_seconds: 30.0
  exponential_base: 2.0
  jitter: true

# Cache Configuration
cache:
  enabled: true
  ttl_seconds: 3600             # 1 hour
  max_size_mb: 100

# Safety & Sandbox
safety:
  sandbox_enabled: true
  max_file_size_mb: 100
  allowed_paths:
    - "."
  blocked_commands:
    - "rm -rf /"
    - "dd if="
    - ":(){ :|:& };:"

# Proactive Monitoring
monitoring:
  enabled: true
  check_interval_seconds: 300   # 5 minutes
  disk_warning_threshold: 0.8   # Warn at 80%
  disk_critical_threshold: 0.9  # Critical at 90%
  cpu_warning_threshold: 0.8
  memory_warning_threshold: 0.85

# Feature Flags
features:
  voice_interface: false        # Experimental
  multi_agent: false            # Experimental
  proactive_monitoring: true
  tree_of_thoughts: true
  prompt_evolution: true
  goal_inference: true
  self_reflection: true
  data_visualization: true

# Profile-Specific Overrides
profiles:
  dev:
    llm:
      temperature: 0.9          # More creative in dev
    cache:
      ttl_seconds: 300          # Shorter cache in dev
    safety:
      sandbox_enabled: false    # Disabled in dev for convenience
  
  staging:
    llm:
      temperature: 0.7
    cache:
      ttl_seconds: 1800         # 30 minutes
    safety:
      sandbox_enabled: true
  
  production:
    llm:
      temperature: 0.5          # More conservative
    cache:
      ttl_seconds: 3600         # 1 hour
    safety:
      sandbox_enabled: true
    features:
      voice_interface: false
      multi_agent: true         # Stable features only

# Web Search
# Zenus automatically searches the web for time-sensitive queries (sports
# schedules, software versions, news, prices…). No key needed — a
# multi-source fallback (Wikipedia, HackerNews, GitHub, Reddit, arXiv,
# RSS feeds, DDG) is always available.
search:
  # Brave Search API key for full web index coverage.
  # Free tier: 2,000 req/month — https://brave.com/search/api
  # Leave empty to use the key-free multi-source fallback.
  brave_api_key:            # or set BRAVE_SEARCH_API_KEY env var

# Debug output controls
# All flags default to false — users see clean output by default.
# Developers can enable specific subsystems without drowning in noise.
# Environment variable equivalents are listed next to each flag.
debug:
  # Master switch: enables all subsystem flags below.
  # Runtime: ZENUS_DEBUG=1
  enabled: false

  # Routing decisions, task-complexity scores, Tree of Thoughts exploration,
  # provider/model override notices, and intent-cache hits.
  # Runtime: ZENUS_DEBUG_ORCHESTRATOR=1
  orchestrator: false

  # Prompt-evolution promotions and internal brain events.
  # Runtime: ZENUS_DEBUG_BRAIN=1
  brain: false

  # Per-step execution output (tool.action: result) and
  # parallel-to-sequential fallback notices.
  # Runtime: ZENUS_DEBUG_EXECUTION=1
  execution: false

  # TTS/STT initialisation messages and voice pipeline internals.
  # Runtime: ZENUS_DEBUG_VOICE=1
  voice: false

  # Search query category, source breakdown, and raw result snippets.
  # Also enabled by legacy ZENUS_SEARCH_DEBUG for backwards compatibility.
  # Runtime: ZENUS_DEBUG_SEARCH=1
  search: false

# MCP (Model Context Protocol) Integration
# Zenus can run as an MCP server (so Claude Code / Cline can call Zenus tools)
# and/or connect to external MCP servers as additional tool sources.
mcp:
  # --- Server mode ---
  # Expose Zenus tools to any MCP-compatible client (Claude Code, Cline, etc.)
  # Start with: zenus mcp-server
  server:
    enabled: false
    # Expose privileged tools (ShellOps, CodeExec) over MCP.
    # Only enable in fully trusted, local environments.
    allow_privileged: false
    # Transport: 'stdio' for Claude Code / Cline, 'sse' for HTTP clients.
    transport: stdio
    # SSE host/port (only used when transport: sse)
    host: 127.0.0.1
    port: 8765

  # --- Client mode ---
  # Connect to external MCP servers and expose their tools inside Zenus.
  client:
    enabled: false
    servers: []
    # Example entries:
    # - name: filesystem          # unique prefix for this server's tools
    #   transport: stdio
    #   command: "uvx mcp-server-filesystem /home/user/docs"
    # - name: remote-tools
    #   transport: sse
    #   url: "http://localhost:8080/sse"

# ─────────────────────────────────────────────────────────────────────────────
# Phase 1.6 — Agentic Harness Hardening
# ─────────────────────────────────────────────────────────────────────────────

# Hook Pipeline — run shell commands before/after every tool execution
# Pre-hooks that exit non-zero DENY the tool call.
# Post-hooks observe results; their exit code is logged only.
hooks:
  pre_tool_use:  []
  # Example — deny rm -rf in bash commands:
  # - match: "ShellOps"
  #   command: "echo \"[hook] ShellOps call: $ZENUS_ACTION\" && exit 0"
  #   timeout_seconds: 5
  # - match: "FileOps.delete_file"
  #   command: "bash ~/.zenus/hooks/pre_delete.sh"
  #   timeout_seconds: 10

  post_tool_use: []
  # Example — log every tool result to a file:
  # - match: "*"
  #   command: "echo \"$(date) $ZENUS_TOOL.$ZENUS_ACTION\" >> ~/.zenus/audit.log"
  #   timeout_seconds: 3

# Plan Mode — agent proposes the full plan; you approve before any step runs
plan_mode:
  enabled: false                  # Toggle with /plan command at runtime
  auto_approve_low_risk: false    # Auto-approve risk-0 (READ-only) steps

# Skills Registry — user-extensible slash commands loaded from Markdown files
skills:
  enabled: true
  skills_dir:                     # Defaults to .zenus/skills/ then ~/.zenus/skills/
  load_bundled: true              # Load built-in skills (commit, review-pr, etc.)

# Session Persistence — save and resume sessions across restarts
session:
  persist: true
  sessions_dir:                   # Defaults to ~/.zenus/sessions/
  max_sessions: 50
  compact_threshold: 0.80         # Auto-compact when 80% of context is used

# Output Style — rendering mode for all terminal output
output_style:
  style: rich                     # rich | plain | compact | json

# Custom Settings (optional)
custom:
  # Add your own settings here
  # Example:
  # workspace_path: /path/to/workspace
  # notification_email: user@example.com
