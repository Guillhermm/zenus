# Zenus Configuration

# ============================================
# LLM Backend Selection
# ============================================
# Choose: openai | anthropic | deepseek | ollama
ZENUS_LLM=ollama

# ============================================
# OpenAI Configuration
# ============================================
# Get key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# ============================================
# Anthropic (Claude) Configuration
# ============================================
# Get key from: https://console.anthropic.com/account/keys
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_MAX_TOKENS=4096

# ============================================
# DeepSeek Configuration
# ============================================
# Get key from: https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# LLM_TOKENS=8192

# ============================================
# Ollama Configuration (Local)
# ============================================
# Model options:
# - phi3:mini (3.8GB, recommended)
# - llama3.2:3b (2GB, lightweight)
# - qwen2.5:3b (2.3GB, good reasoning)
OLLAMA_MODEL=phi3:mini

# ============================================
# Web Search
# ============================================
# Zenus automatically searches the web for time-sensitive queries.
# A key-free multi-source fallback (Wikipedia, HackerNews, GitHub,
# Reddit, arXiv, RSS feeds) is always available.
#
# For full web index coverage, get a free Brave Search API key:
# https://brave.com/search/api (2,000 req/month free tier)
# BRAVE_SEARCH_API_KEY=your-key-here

# ============================================
# Debug Output Controls
# ============================================
# All debug output is off by default — users see clean output.
# Prefer setting debug: ... in config.yaml for persistent configuration.
#
# Master switch — enables ALL subsystem flags at once:
# ZENUS_DEBUG=1
#
# Per-subsystem (use instead of the master to limit noise):
# ZENUS_DEBUG_ORCHESTRATOR=1   routing, complexity, ToT, cache hits
# ZENUS_DEBUG_BRAIN=1          prompt evolution, model internals
# ZENUS_DEBUG_EXECUTION=1      per-step execution, parallel fallback
# ZENUS_DEBUG_VOICE=1          TTS/STT init and pipeline messages
# ZENUS_DEBUG_SEARCH=1         search decisions and result breakdown
#
# Legacy alias (still works, maps to ZENUS_DEBUG_SEARCH):
# ZENUS_SEARCH_DEBUG=1
